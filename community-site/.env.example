# Copy to .env for local dev (do not commit .env).
#
# === Vercel Production / Preview (Dashboard → Environment Variables) ===
# Only these two — required for real Supabase data (no mock):
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
#
# After changing env on Vercel, trigger a new deployment (Vite embeds at build time).
# NEVER add SUPABASE_SERVICE_ROLE_KEY or any VITE_* service_role to Vercel.
#
# Maintenance screen (optional; .env.production defaults to on):
# VITE_COMMUNITY_MAINTENANCE=1
# VITE_COMMUNITY_MAINTENANCE_MESSAGE=社区正在进化中，非常抱歉
# Or toggle via Supabase table community_site_status (migration 007).

# Auth maps username to {username}@danmuai.test (not .local — rejected by Supabase)
# Registration uses Edge Function community-register-guard (not client signUp).
# Do NOT put SUPABASE_SERVICE_ROLE_KEY in this file for production builds.
# Optional: COMMUNITY_REGISTRATION_PEPPER in Supabase Function secrets only.

# === Local acceptance only (not for Vercel) ===
# COMMUNITY_TEST_USER_A=user_a
# COMMUNITY_TEST_PASS_A=
# COMMUNITY_TEST_USER_B=user_b
# COMMUNITY_TEST_PASS_B=
# SUPABASE_SERVICE_ROLE_KEY=   # verify:rls cases 9.x/10.x only; never VITE_* or git
